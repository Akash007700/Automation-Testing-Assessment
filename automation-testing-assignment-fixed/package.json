{
  "name": "automation-testing-assignment",
  "version": "1.0.1",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui.spec.js",
    "test:api": "newman run postman/ReqRes.postman_collection.json -e postman/ReqRes.postman_environment.json --reporters cli,html",
    "all": "npm run test && npm run test:api",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "newman": "^6.1.3",
    "newman-reporter-html": "^1.0.5"
  }
}