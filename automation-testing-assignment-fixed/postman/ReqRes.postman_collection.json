{
  "info": {
    "name": "ReqRes API FIXED",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Q3 Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "x-api-key",
            "value": "{{apiKey}}"
          }
        ],
        "url": "{{baseUrl}}/login",
        "body": {
          "mode": "raw",
          "raw": "{\"email\": \"eve.holt@reqres.in\", \"password\": \"cityslicka\"}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('200 OK', function(){ pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.environment.set('token', json.token || '')"
            ]
          }
        }
      ]
    },
    {
      "name": "Q4 Get User",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-api-key",
            "value": "{{apiKey}}"
          }
        ],
        "url": "{{baseUrl}}/users/{{userId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('200 OK', function(){ pm.response.to.have.status(200); });",
              "var d = pm.response.json().data;",
              "pm.expect(d).to.have.property('email');"
            ]
          }
        }
      ]
    },
    {
      "name": "Q5 PUT",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "x-api-key",
            "value": "{{apiKey}}"
          }
        ],
        "url": "{{baseUrl}}/users/2",
        "body": {
          "mode": "raw",
          "raw": "{\"name\": \"Boss\", \"job\": \"QA\"}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('200 OK', function(){ pm.response.to.have.status(200); });",
              "var j = pm.response.json();",
              "pm.expect(j).to.have.property('updatedAt');"
            ]
          }
        }
      ]
    },
    {
      "name": "Q6 PATCH",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "x-api-key",
            "value": "{{apiKey}}"
          }
        ],
        "url": "{{baseUrl}}/users/2",
        "body": {
          "mode": "raw",
          "raw": "{\"job\": \"QA Engineer\"}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('200 OK', function(){ pm.response.to.have.status(200); });",
              "var j = pm.response.json();",
              "pm.expect(j.job).to.eql('QA Engineer');"
            ]
          }
        }
      ]
    },
    {
      "name": "Q8 Bad Request",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "x-api-key",
            "value": "{{apiKey}}"
          }
        ],
        "url": "{{baseUrl}}/login",
        "body": {
          "mode": "raw",
          "raw": "{\"email\": \"peter@klaven\"}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('400 expected', function(){ pm.response.to.have.status(400); });"
            ]
          }
        }
      ]
    }
  ]
}